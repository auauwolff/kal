# WorkOS AuthKit Configuration (Frontend)
VITE_WORKOS_CLIENT_ID=YOUR-WORKOS-CLIENT-ID
VITE_WORKOS_REDIRECT_URI=http://localhost:5173/callback
# Optional for production cookie sessions: e.g. auth.yourdomain.com
# If omitted, the app keeps AuthKit devMode on as a prototype fallback.
VITE_WORKOS_API_HOSTNAME=
# Optional explicit override: true stores refresh tokens locally, false requires cookie sessions.
VITE_WORKOS_DEV_MODE=

# Convex Configuration
VITE_CONVEX_URL=your-convex-url
